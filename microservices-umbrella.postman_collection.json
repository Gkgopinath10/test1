{
  "info": {
    "_postman_id": "ms-umbrella-java8-collection",
    "name": "Microservices Umbrella - Java 8",
    "description": "Complete Postman collection for Microservices Umbrella project.\nServices:\n- Eureka Server     : http://localhost:8761\n- Product Service   : http://localhost:8081\n- Finance Service   : http://localhost:8082\n- Customer Service  : http://localhost:8083\n\nRun Order:\n1. Health Checks\n2. Eureka Registry\n3. Customer Service\n4. Product Service\n5. Finance Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "eureka_url",   "value": "http://localhost:8761" },
    { "key": "product_url",  "value": "http://localhost:8081" },
    { "key": "finance_url",  "value": "http://localhost:8082" },
    { "key": "customer_url", "value": "http://localhost:8083" }
  ],
  "item": [

    {
      "name": "01 - Health Checks",
      "description": "Check all services are UP before running tests",
      "item": [
        {
          "name": "Eureka Server Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{eureka_url}}/actuator/health", "host": ["{{eureka_url}}"], "path": ["actuator","health"] },
            "description": "Check if Eureka Server is running"
          },
          "response": []
        },
        {
          "name": "Product Service Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{product_url}}/actuator/health", "host": ["{{product_url}}"], "path": ["actuator","health"] },
            "description": "Check if Product Service is running"
          },
          "response": []
        },
        {
          "name": "Finance Service Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{finance_url}}/actuator/health", "host": ["{{finance_url}}"], "path": ["actuator","health"] },
            "description": "Check if Finance Service is running"
          },
          "response": []
        },
        {
          "name": "Customer Service Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{customer_url}}/actuator/health", "host": ["{{customer_url}}"], "path": ["actuator","health"] },
            "description": "Check if Customer Service is running"
          },
          "response": []
        }
      ]
    },

    {
      "name": "02 - Eureka Registry",
      "description": "Verify all microservices are registered in Eureka",
      "item": [
        {
          "name": "Get All Registered Services",
          "request": {
            "method": "GET",
            "url": { "raw": "{{eureka_url}}/eureka/apps", "host": ["{{eureka_url}}"], "path": ["eureka","apps"] },
            "description": "View all microservices registered in Eureka registry"
          },
          "response": []
        },
        {
          "name": "Check PRODUCT-SERVICE in Eureka",
          "request": {
            "method": "GET",
            "url": { "raw": "{{eureka_url}}/eureka/apps/PRODUCT-SERVICE", "host": ["{{eureka_url}}"], "path": ["eureka","apps","PRODUCT-SERVICE"] },
            "description": "Verify product-service is registered"
          },
          "response": []
        },
        {
          "name": "Check FINANCE-SERVICE in Eureka",
          "request": {
            "method": "GET",
            "url": { "raw": "{{eureka_url}}/eureka/apps/FINANCE-SERVICE", "host": ["{{eureka_url}}"], "path": ["eureka","apps","FINANCE-SERVICE"] },
            "description": "Verify finance-service is registered"
          },
          "response": []
        },
        {
          "name": "Check CUSTOMER-SERVICE in Eureka",
          "request": {
            "method": "GET",
            "url": { "raw": "{{eureka_url}}/eureka/apps/CUSTOMER-SERVICE", "host": ["{{eureka_url}}"], "path": ["eureka","apps","CUSTOMER-SERVICE"] },
            "description": "Verify customer-service is registered"
          },
          "response": []
        }
      ]
    },

    {
      "name": "03 - Customer Service",
      "description": "Customer Registration CRUD - Run this BEFORE Finance Service tests. Customers must be ACTIVE for Finance transactions.",
      "item": [
        {
          "name": "CRUD",
          "item": [
