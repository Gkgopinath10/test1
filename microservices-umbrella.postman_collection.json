            {
              "name": "Delete Customer 3 - Raj",
              "request": {
                "method": "DELETE",
                "url": { "raw": "{{customer_url}}/api/customers/3", "host": ["{{customer_url}}"], "path": ["api","customers","3"] },
                "description": "Permanently delete a customer record.\nExpected: 204 No Content"
              },
              "response": []
            }
          ]
        },
