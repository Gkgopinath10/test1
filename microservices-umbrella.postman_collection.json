                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{customer_url}}/api/customers", "host": ["{{customer_url}}"], "path": ["api","customers"] },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"firstName\": \"Raj\",\n  \"lastName\": \"Kumar\",\n  \"email\": \"raj.kumar@example.com\",\n  \"phone\": \"+9876543210\",\n  \"address\": \"789 Park Road\",\n  \"city\": \"Chennai\",\n  \"country\": \"India\",\n  \"dateOfBirth\": \"1995-03-10\"\n}"
