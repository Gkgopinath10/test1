              "name": "Register Customer 1 - John Doe (USA)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{customer_url}}/api/customers", "host": ["{{customer_url}}"], "path": ["api","customers"] },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"+1234567890\",\n  \"address\": \"123 Main Street\",\n  \"city\": \"New York\",\n  \"country\": \"USA\",\n  \"dateOfBirth\": \"1990-05-15\"\n}"
                },
                "description": "Register a new customer. Status starts as PENDING by default.\nExpected: 201 Created"
              },
              "response": []
            },
            {
              "name": "Register Customer 2 - Jane Smith (USA)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
