    {
      "name": "05 - Finance Service",
      "description": "Finance CRUD with Inter-Service Calls via Eureka.\nPREREQUISITE: Customer 1 and 2 must be ACTIVE. Products 1,2,3 must exist.\nWhen creating a transaction:\n- Calls customer-service to validate customerId (must be ACTIVE)\n- Calls product-service to validate productId (must be active + in stock)\n- Returns enriched response with customerName, customerEmail, productName",
      "item": [
        {
          "name": "CRUD",
          "item": [
            {
              "name": "Create Transaction - PAYMENT (Customer1 + Product1)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{finance_url}}/api/transactions", "host": ["{{finance_url}}"], "path": ["api","transactions"] },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"referenceNumber\": \"TXN-2024-001\",\n  \"amount\": 1299.99,\n  \"transactionType\": \"PAYMENT\",\n  \"accountNumber\": \"ACC-123456\",\n  \"description\": \"Laptop purchase payment\",\n  \"currency\": \"USD\",\n  \"customerId\": 1,\n  \"productId\": 1\n}"
                },
                "description": "Create a PAYMENT transaction.\nInternally calls:\n- customer-service: validates customerId=1 (must be ACTIVE)\n- product-service: validates productId=1 (must be active + in stock)\nResponse includes customerName, customerEmail, productName.\nExpected: 201 Created"
              },
              "response": []
            },
            {
              "name": "Create Transaction - CREDIT (Customer1 only)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{finance_url}}/api/transactions", "host": ["{{finance_url}}"], "path": ["api","transactions"] },
                "body": {
                  "mode": "raw",
