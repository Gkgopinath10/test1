                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"email\": \"jane.smith@example.com\",\n  \"phone\": \"+0987654321\",\n  \"address\": \"456 Oak Avenue\",\n  \"city\": \"Los Angeles\",\n  \"country\": \"USA\",\n  \"dateOfBirth\": \"1985-08-22\"\n}"
                },
                "description": "Register second customer.\nExpected: 201 Created"
